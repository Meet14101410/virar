<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Virar - Western Line Terminal</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #fdf2f2; display: flex; justify-content: center; padding: 20px; }
        .city-card { background: white; width: 480px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); overflow: hidden; border-bottom: 8px solid #c0392b; }
        .header { background: #c0392b; color: white; padding: 25px; text-align: center; }
        .content { padding: 30px; color: #2c3e50; }
        .info { margin-bottom: 12px; display: flex; justify-content: space-between; border-bottom: 1px solid #eee; padding-bottom: 8px; }
        .label { font-weight: bold; color: #c0392b; }
    </style>
</head>
<body>
    <div class="city-card">
        <div class="header"><h1>🚉 Virar</h1><p>The Final Frontier of the Western Line</p></div>
        <div class="content">
            <div class="info"><span class="label">District:</span><span>Palghar</span></div>
            <div class="info"><span class="label">Railway Code:</span><span>VR</span></div>
            <div class="info"><span class="label">Famous For:</span><span>Jivdani Temple & Arnala Beach</span></div>
            <div class="info"><span class="label">Pincode:</span><span>401303</span></div>
        </div>
    </div>
</body>
</html>
